# ShelKit Configuration

# Server
PORT=3000
BASE_DOMAIN=shelkit.forestinfra.com

# Shelby Protocol (leave SHELBY_PRIVATE_KEY empty to use stub mode)
SHELBY_API_KEY=YOUR_GEOMI_API_KEY
SHELBY_PRIVATE_KEY=
SHELBY_NETWORK=testnet
BLOB_EXPIRY_DAYS=365

# Auth
JWT_SECRET=change-me-in-production

# Admin (keep this secret — used to suspend wallets/deployments and view abuse reports)
ADMIN_SECRET=change-me-to-a-strong-secret

# Cloudflare (for wildcard SSL cert via DNS challenge)
CF_KEY=your-cloudflare-global-api-key
CF_EMAIL=your-cloudflare-email

# Database
DB_PATH=./server/data/shelkit.db
